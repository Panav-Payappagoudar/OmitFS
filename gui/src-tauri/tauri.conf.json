{
  "productName": "OmitFS",
  "version": "0.3.0",
  "identifier": "dev.omitfs.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3031",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "app": {
    "windows": [
      {
        "label":         "main",
        "title":         "OmitFS",
        "width":         780,
        "height":        560,
        "minWidth":      600,
        "minHeight":     400,
        "decorations":   false,
        "transparent":   true,
        "visible":       false,
        "center":        true,
        "alwaysOnTop":   true,
        "skipTaskbar":   true,
        "resizable":     true
      }
    ],
    "trayIcon": {
      "iconPath":       "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "security": {
      "csp": "default-src 'self'; connect-src http://localhost:3031 'self'; style-src 'unsafe-inline'"
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "sidecar": false,
      "scope": [
        { "name": "omitfs", "cmd": "omitfs", "args": true }
      ]
    },
    "global-shortcut": {}
  }
}
